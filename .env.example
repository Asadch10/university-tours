# ----------------------------------------------------------------------------
# University Campus Private Tours — environment template
# Copy to .env and fill in. NEVER commit a real .env.
# (Reminder: keep values quoted if they contain spaces.)
# ----------------------------------------------------------------------------

NODE_ENV=development

# --- Database (PostgreSQL 15+) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ucpt?schema=public

# --- Redis (cache, queues, rate limits, socket adapter) ---
REDIS_URL=redis://localhost:6379

# --- Auth (JWT access + refresh, Argon2id) ---
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Backend API ---
API_PORT=4000
API_BASE_URL=http://localhost:4000
CORS_ALLOWLIST=http://localhost:3000,http://localhost:3001

# --- Worker ---
WORKER_PORT=4001
SOCKET_PORT=4002

# --- Stripe (manual-capture intents, refunds, webhooks) ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# --- Object storage (S3 / Cloudflare R2) ---
STORAGE_BUCKET=ucpt-documents
STORAGE_REGION=auto
STORAGE_ENDPOINT=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=

# --- Email (SES / Mailgun) ---
EMAIL_FROM=no-reply@ucpt.example
EMAIL_PROVIDER=ses

# --- Public clients ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000

# --- Platform defaults (also configurable at runtime via admin) ---
DEFAULT_COMMISSION_PCT=25
BOOKING_REQUEST_EXPIRY_HOURS=6
BOOKING_AUTOCOMPLETE_HOURS=48
